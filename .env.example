# ============================================
# MDTA Digital Knowledge Center — Environment Variables
# ============================================
# Copy this file to `.env` (local) or set these in your Vercel project settings.

# ---------- DATABASE (Supabase PostgreSQL) ----------
# IMPORTANT: For Vercel/serverless, use the CONNECTION POOLER URL (port 6543).
# For prisma migrate/db push, use the DIRECT URL (port 5432).
#
# Replace [YOUR-PASSWORD] with your Supabase database password.
#
# Connection Pooler (for Vercel runtime — Transaction mode):
DATABASE_URL="postgresql://postgres.tahvikmhjbupxzryofuz:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Direct Connection (for prisma migrate/db push — Session mode):
DIRECT_URL="postgresql://postgres.tahvikmhjbupxzryofuz:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"
#
# Alternative: Direct connection (works but not recommended for serverless):
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.tahvikmhjbupxzryofuz.supabase.co:5432/postgres"
# DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.tahvikmhjbupxzryofuz.supabase.co:5432/postgres"
#
# NOTE: Find your pooler URL in Supabase Dashboard → Project Settings → Database → Connection string → Transaction pooler

# ---------- AUTH ----------
# Secret for signing JWT session tokens. Generate with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-32-char-random-string"

# Initial super admin (only used on first run to seed the admin user)
ADMIN_EMAIL="admin@mdta-miftahululum.sch.id"
ADMIN_PASSWORD="admin12345"
ADMIN_NAME="Super Admin"

# ---------- SITE ----------
# Public URL of your deployed site (used for SEO, sitemap, RSS feed, OpenGraph)
NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"

# ---------- OPTIONAL ----------
# Google Analytics ID (e.g., G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_ID=""
