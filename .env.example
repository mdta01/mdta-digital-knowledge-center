# ============================================
# MDTA Digital Knowledge Center — Environment Variables
# ============================================
# Copy this file to `.env` (local) or set these in your Vercel project settings.

# ---------- DATABASE (Supabase PostgreSQL) ----------
# Supabase Project: tahvikmhjbupxzryofuz
# Region: ap-southeast-1 (Shared Pooler: aws-1-ap-southeast-1)
#
# For Vercel serverless runtime (Transaction pooler — port 6543):
# IMPORTANT: connection_limit=1 + pool_timeout=30 are required for PgBouncer/Supavisor.
# pgbouncer=true enables transaction-mode pooling (serverless-friendly).
# pool_timeout=30 gives queries 30s to acquire a connection (default 10s is too short).
DATABASE_URL="postgresql://postgres.tahvikmhjbupxzryofuz:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=30"
#
# For prisma migrate/db push (Session pooler — port 5432):
DIRECT_URL="postgresql://postgres.tahvikmhjbupxzryofuz:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
#
# NOTE: Both URLs use the same password. Find them in:
# Supabase Dashboard → Project Settings → Database → Connection string → Shared Pooler

# ---------- AUTH ----------
# Secret for signing JWT session tokens. Generate with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-32-char-random-string"

# Initial super admin (only used on first run to seed the admin user)
ADMIN_EMAIL="mdtadigital@center"
ADMIN_PASSWORD="mdta@01"
ADMIN_NAME="Super Admin"

# ---------- SITE ----------
# Public URL of your deployed site (used for SEO, sitemap, RSS feed, OpenGraph)
NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"
