# ============================================
# MDTA Digital Knowledge Center — Environment Variables
# ============================================
# Copy this file to `.env` (local) or set these in your Vercel project settings.

# ---------- DATABASE ----------
# Local dev (SQLite — filesystem-based, NOT for production):
DATABASE_URL="file:./db/custom.db"

# Vercel/Production (PostgreSQL via Supabase/Neon/PlanetScale):
# 1. Change provider in prisma/schema.prisma to "postgresql"
# 2. Set DATABASE_URL to your Postgres connection string:
# DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"
# DIRECT_URL="postgresql://user:password@host:port/dbname"  # for migrations

# ---------- AUTH ----------
# Secret for signing JWT session tokens. Generate with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-32-char-random-string"

# Initial super admin (only used on first run to seed the admin user)
ADMIN_EMAIL="admin@mdta-miftahululum.sch.id"
ADMIN_PASSWORD="admin12345"
ADMIN_NAME="Super Admin"

# ---------- SITE ----------
# Public URL of your deployed site (used for SEO, sitemap, RSS feed, OpenGraph)
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# ---------- OPTIONAL ----------
# Google Analytics ID (e.g., G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_ID=""
